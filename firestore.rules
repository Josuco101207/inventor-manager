rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════
    // FUNCIONES AUXILIARES
    // ═══════════════════════════════════════════════════════════════
    
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserDoc() && userDoc().data.role == 'admin';
    }

    function isStaff() {
      return hasUserDoc() &&
        (userDoc().data.role == 'admin' || userDoc().data.role == 'almacenista');
    }

    function allowedCategories() {
      return userDoc().data.allowedCategories;
    }

    function editableCategories() {
      return userDoc().data.editableCategories;
    }

    function canCreateCategory(category) {
      return isAdmin() || (isStaff() && category in allowedCategories());
    }

    function canEditCategory(category) {
      return isAdmin() || (isStaff() && category in editableCategories());
    }

    // Validación: No permitir campos de sistema
    function noSystemFields(data) {
      return !('createdAt' in data) && !('updatedAt' in data);
    }

    // Validación: Timestamp válido
    function validTimestamp(field) {
      return !(field in request.resource.data) || 
        request.resource.data[field] is timestamp ||
        request.resource.data[field] is string;
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: USERS
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      // Crear: Solo admin o el propio usuario (primer login)
      allow create: if signedIn()
        && !('password' in request.resource.data)  // NUNCA guardar passwords
        && (isAdmin() || request.auth.uid == userId);

      // Update: Admin puede todo, usuario solo su perfil básico
      allow update: if signedIn()
        && !('password' in request.resource.data)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'displayName', 'email', 'photoURL', 'sysKey'])
          )
        );

      allow delete: if isAdmin() && request.auth.uid != userId;  // No auto-delete
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: ITEMS (Inventario)
    // ═══════════════════════════════════════════════════════════════
    match /items/{itemId} {
      allow read: if isStaff();
      
      allow create: if isStaff() 
        && canCreateCategory(request.resource.data.category)
        && request.resource.data.keys().hasAny(['name', 'category'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && validTimestamp('timestamp');
      
      allow update: if isStaff() 
        && canEditCategory(resource.data.category)
        && (request.resource.data.category == resource.data.category || canCreateCategory(request.resource.data.category))
        && validTimestamp('timestamp');
      
      allow delete: if isStaff() && canEditCategory(resource.data.category);
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: MOVEMENTS (Historial)
    // ═══════════════════════════════════════════════════════════════
    match /movements/{movementId} {
      allow read: if isStaff();
      
      // Crear: Solo append-only, validar campos requeridos
      allow create: if isStaff()
        && canCreateCategory(request.resource.data.category)
        && request.resource.data.keys().hasAll(['action', 'item', 'qty'])
        && request.resource.data.action in ['Entrada', 'Salida', 'Préstamo', 'Devolución', 'Falla/Manto', 'Auditoría', 'Alta', 'Edición', 'Eliminación', 'Anulación', 'Asignación', 'Transferencia', 'Movimiento de Sección']
        && request.resource.data.qty is number
        && request.resource.data.qty >= 0
        && validTimestamp('timestamp');
      
      // Update: Solo permitir anulación (marcar como anulado)
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['annulled', 'annulledBy', 'annulledAt'])
        && request.resource.data.annulled == true
        && resource.data.annulled != true;  // Solo una vez
      
      // NUNCA permitir borrar movimientos (auditoría)
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIONES AUXILIARES
    // ═══════════════════════════════════════════════════════════════
    match /personnel/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.keys().hasAll(['name']);
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /brands/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.keys().hasAll(['name']);
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /whatsapp_users/{docId} {
      allow read, write: if isAdmin();
    }

    match /locations/{docId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.keys().hasAll(['name']);
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /custom_categories/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: INVOICES (Facturas)
    // ═══════════════════════════════════════════════════════════════
    match /invoices/{invoiceId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.keys().hasAll(['folio', 'proveedor']);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: STATS (Precalculadas - solo backend/functions)
    // ═══════════════════════════════════════════════════════════════
    match /stats/{docId} {
      allow read: if isStaff();
      allow write: if false;  // Solo Cloud Functions
    }
  }
}
